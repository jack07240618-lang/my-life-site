---
import type { CollectionEntry } from 'astro:content';

interface Props {
	entry: CollectionEntry<'journal'>;
	index: number;
}

const { entry, index } = Astro.props;
const base = import.meta.env.BASE_URL;
const date = entry.data.date.toLocaleDateString('zh-CN', {
	year: 'numeric',
	month: '2-digit',
	day: '2-digit',
});
---

<article class="border-t border-line py-9 sm:py-12">
	<a class="group grid gap-5 sm:grid-cols-[10rem_1fr] sm:gap-10 lg:grid-cols-[13rem_1fr]" href={`${base}journal/${entry.id}/`}>
		<div class="flex items-center justify-between gap-4 sm:block">
			<time class="text-sm text-muted" datetime={entry.data.date.toISOString()}>{date}</time>
			<p class="mt-0 text-[0.65rem] tracking-[0.14em] text-muted uppercase sm:mt-3">
				{String(index + 1).padStart(2, '0')}
			</p>
		</div>

		<div class="grid gap-5 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,0.7fr)] lg:gap-16">
			<div>
				<h2 class="text-2xl leading-tight font-medium tracking-[-0.035em] transition-opacity group-hover:opacity-55 sm:text-3xl">
					{entry.data.title}
				</h2>
				<ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-[0.68rem] tracking-[0.08em] text-muted">
					{entry.data.tags.map((tag) => <li>#{tag}</li>)}
				</ul>
			</div>
			<p class="max-w-xl text-sm leading-7 text-muted sm:text-base sm:leading-8">{entry.data.description}</p>
		</div>
	</a>
</article>
