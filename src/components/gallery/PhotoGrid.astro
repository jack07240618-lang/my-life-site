---
import { Image } from 'astro:assets';
import type { GalleryPhoto } from '../../data/gallery';

interface Props {
	photos: GalleryPhoto[];
}

const { photos } = Astro.props;

const sizeClasses = {
	landscape: 'aspect-[4/3]',
	portrait: 'aspect-[3/4]',
	square: 'aspect-square',
};

---

<div class="grid items-start gap-x-5 gap-y-14 sm:grid-cols-2 sm:gap-x-7 sm:gap-y-20 lg:gap-x-10 lg:gap-y-28">
	{
		photos.map((photo, index) => (
			<figure class:list={['group', { 'sm:mt-32': index % 2 === 1 }]}>
				<div class:list={['relative overflow-hidden bg-paper', sizeClasses[photo.format]]}>
					<Image
						class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.015]"
						src={photo.image}
						alt={photo.alt}
						widths={[480, 720, 960]}
						sizes="(min-width: 640px) 46vw, 100vw"
						loading={index < 2 ? 'eager' : 'lazy'}
					/>
					<span class="absolute top-4 right-4 text-[0.62rem] tracking-[0.14em] text-white/80 uppercase">
						{String(index + 1).padStart(2, '0')}
					</span>
				</div>
				<figcaption class="mt-4 flex items-start justify-between gap-6 border-t border-line pt-4">
					<div>
						<h2 class="text-sm font-medium tracking-[-0.01em]">{photo.title}</h2>
						<p class="mt-1 text-xs text-muted">{photo.location}</p>
					</div>
					<div class="text-right text-[0.65rem] leading-5 tracking-[0.08em] text-muted uppercase">
						<p>{photo.category}</p>
						<p>{photo.year}</p>
					</div>
				</figcaption>
			</figure>
		))
	}
</div>
