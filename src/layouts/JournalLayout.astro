---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';

interface Props {
	entry: CollectionEntry<'journal'>;
}

const { entry } = Astro.props;
const base = import.meta.env.BASE_URL;
const date = entry.data.date.toLocaleDateString('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<BaseLayout title={`${entry.data.title} — Journal`} description={entry.data.description}>
	<article class="page-shell pb-28 pt-20 sm:pb-36 sm:pt-28 lg:pt-36">
		<header class="mx-auto max-w-4xl border-b border-line pb-12 sm:pb-16">
			<a class="mb-12 inline-block text-xs tracking-[0.14em] text-muted uppercase hover:text-ink" href={`${base}journal/`}>
				← Journal
			</a>
			<p class="mb-6 text-xs tracking-[0.12em] text-muted uppercase">{date}</p>
			<h1 class="text-[clamp(2.8rem,7vw,5.5rem)] leading-[0.98] font-semibold tracking-[-0.055em]">
				{entry.data.title}
			</h1>
			<p class="mt-8 max-w-2xl text-lg leading-8 text-muted sm:text-xl">{entry.data.description}</p>
			<ul class="mt-8 flex flex-wrap gap-4 text-xs text-muted">
				{entry.data.tags.map((tag) => <li>#{tag}</li>)}
			</ul>
		</header>

		<div class="journal-prose mx-auto mt-12 max-w-3xl sm:mt-16">
			<slot />
		</div>
	</article>
</BaseLayout>

<style is:global>
	.journal-prose {
		font-size: 1.05rem;
		line-height: 2;
		color: #333333;
	}

	.journal-prose p {
		margin-block: 1.6em;
	}

	.journal-prose h2 {
		margin-top: 2.8em;
		margin-bottom: 0.8em;
		font-size: 1.65rem;
		line-height: 1.25;
		letter-spacing: -0.035em;
		color: #111111;
	}

	.journal-prose a {
		text-decoration: underline;
		text-underline-offset: 0.2em;
	}

	.journal-prose blockquote {
		margin-block: 2em;
		border-left: 1px solid #111111;
		padding-left: 1.5rem;
		color: #6e6e73;
	}

	@media (min-width: 640px) {
		.journal-prose {
			font-size: 1.125rem;
		}
	}
</style>
