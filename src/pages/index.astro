---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import morningStillness from '../assets/gallery/morning-stillness-hd.webp';
import betweenWalls from '../assets/gallery/between-walls-hd.webp';
import roadToTheSea from '../assets/gallery/road-to-the-sea-hd.webp';
import { timelineEvents } from '../data/timeline';
import MomentFeed from '../components/moments/MomentFeed.astro';

const recentUpdates = timelineEvents.slice(0, 3);
const base = import.meta.env.BASE_URL;
---

<BaseLayout>
	<section class="relative min-h-[100svh] overflow-hidden bg-[#242722] text-white">
		<Image
			class="hero-image absolute inset-0 h-full w-full object-cover"
			src={morningStillness}
			alt="晨雾中的山脉与湖面"
			width={2560}
			height={1440}
			widths={[960, 1440, 1920, 2560]}
			sizes="100vw"
			format="webp"
			quality={88}
			loading="eager"
		/>
		<div class="absolute inset-0 bg-black/38"></div>
		<div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(10,12,10,.52),transparent_75%)]"></div>
		<div class="page-shell relative flex min-h-[100svh] flex-col justify-end pb-12 pt-32 sm:pb-16 lg:pb-20">
			<p class="mb-7 text-[0.66rem] tracking-[0.24em] text-white/70 uppercase">Personal Archive · 2026</p>
			<h1 class="font-display max-w-5xl text-[clamp(4rem,11vw,9.5rem)] leading-[0.82] font-normal tracking-normal">
				Discover<br />the quiet world
			</h1>
			<div class="mt-10 flex flex-col justify-between gap-8 border-t border-white/30 pt-6 sm:flex-row sm:items-end">
				<p class="max-w-md text-base leading-7 text-white/78 sm:text-lg">Explore moments beyond ordinary experience.</p>
				<a class="group inline-flex w-fit items-center gap-5 rounded-full border border-white/45 bg-white/12 px-6 py-3 text-[0.68rem] tracking-[0.14em] uppercase backdrop-blur-md transition duration-300 hover:-translate-y-1 hover:bg-white hover:text-ink" href={`${base}gallery`}>
					View the archive <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">→</span>
				</a>
			</div>
		</div>
	</section>

	<section class="page-shell py-24 sm:py-36 lg:py-48" aria-label="精选项目">
		<div class="reveal mb-16 flex items-center justify-between border-b border-line pb-5 text-[0.65rem] tracking-[0.18em] text-muted uppercase sm:mb-24">
			<p>Selected Observations</p><p>01 — 02</p>
		</div>

		<article class="reveal grid gap-8 lg:grid-cols-[minmax(0,7fr)_minmax(17rem,3fr)] lg:items-end lg:gap-16">
			<div class="group overflow-hidden rounded-[28px] bg-paper">
				<Image class="aspect-[4/3] w-full object-cover transition-transform duration-[1400ms] ease-out group-hover:scale-[1.025]" src={betweenWalls} alt="清水混凝土建筑中的行人" width={2048} height={1536} widths={[640, 960, 1440, 1920]} sizes="(min-width:1024px) 68vw, 100vw" format="webp" quality={88} />
			</div>
			<div class="pb-2">
				<p class="text-[0.65rem] tracking-[0.2em] text-forest uppercase">Project / 2026</p>
				<h2 class="font-display mt-6 text-5xl leading-[0.95] sm:text-6xl">Between<br />Walls</h2>
				<p class="mt-7 max-w-sm text-base leading-8 text-muted">在尺度、光线与人的短暂经过之间，建筑显露出安静的秩序。</p>
			</div>
		</article>

		<article class="reveal mt-24 grid gap-8 sm:mt-36 lg:mt-48 lg:grid-cols-[minmax(17rem,3fr)_minmax(0,7fr)] lg:items-end lg:gap-16">
			<div class="pb-2 lg:order-1">
				<p class="text-[0.65rem] tracking-[0.2em] text-forest uppercase">Journey / 2026</p>
				<h2 class="font-display mt-6 text-5xl leading-[0.95] sm:text-6xl">Road to<br />the Sea</h2>
				<p class="mt-7 max-w-sm text-base leading-8 text-muted">沿着海岸继续前行。目的地并不重要，路本身保留了全部记忆。</p>
			</div>
			<div class="group overflow-hidden rounded-[28px] bg-paper lg:order-2">
				<Image class="aspect-[4/3] w-full object-cover transition-transform duration-[1400ms] ease-out group-hover:scale-[1.025]" src={roadToTheSea} alt="深色海岸线旁的公路" width={2048} height={1536} widths={[640, 960, 1440, 1920]} sizes="(min-width:1024px) 68vw, 100vw" format="webp" quality={88} />
			</div>
		</article>
	</section>

	<section class="page-shell pb-24 sm:pb-36 lg:pb-48" aria-label="最新动态">
		<div class="reveal mb-12 flex items-end justify-between border-b border-line pb-5 sm:mb-16">
			<div><p class="mb-3 text-[0.65rem] tracking-[0.18em] text-forest uppercase">New Moments</p><h2 class="font-display text-5xl sm:text-6xl">From the field</h2></div>
			<a class="hidden text-[0.65rem] tracking-[0.14em] text-muted uppercase transition hover:text-ink sm:block" href={`${base}moments`}>View all →</a>
		</div>
		<div class="mx-auto max-w-4xl"><MomentFeed limit={2} compact /></div>
	</section>

	<section class="bg-[#252824] py-24 text-white sm:py-32 lg:py-40">
		<div class="page-shell reveal">
			<div class="mb-14 flex items-end justify-between border-b border-white/18 pb-6 sm:mb-20">
				<div><p class="mb-4 text-[0.65rem] tracking-[0.2em] text-white/45 uppercase">Recently</p><h2 class="font-display text-5xl sm:text-6xl">Current notes</h2></div>
				<a class="hidden text-[0.65rem] tracking-[0.14em] text-white/55 uppercase transition hover:text-white sm:block" href={`${base}timeline`}>View timeline →</a>
			</div>
			<div>
				{recentUpdates.map((update, index) => (
					<article class="group grid gap-5 border-b border-white/15 py-8 transition-transform duration-300 hover:translate-x-2 sm:grid-cols-[7rem_1fr] sm:py-10 lg:grid-cols-[9rem_1fr_1fr] lg:gap-12">
						<p class="text-xs tracking-[0.1em] text-white/45">{update.date}<br /><span class="mt-2 inline-block uppercase">{update.category}</span></p>
						<h3 class="text-xl font-medium sm:text-2xl"><span class="mr-4 text-xs text-white/35">0{index + 1}</span>{update.title}</h3>
						<p class="max-w-lg text-sm leading-7 text-white/55 sm:text-base">{update.description}</p>
					</article>
				))}
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	@media (prefers-reduced-motion: no-preference) {
		.hero-image { animation: hero-scale 16s ease-out both; }
	}
	@keyframes hero-scale { from { transform: scale(1.06); } to { transform: scale(1); } }
</style>
